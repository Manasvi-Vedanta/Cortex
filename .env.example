# GenMentor Environment Variables
# Copy this file to .env and fill in your actual values

# Google Gemini API Key
GOOGLE_API_KEY=AIzaSyDRf_5b1YQxEyr80pnq9pI8NmT_ZWuNKjs

# Google Search API (optional)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Database Configuration
DATABASE_PATH=genmentor.db

# AI Model Configuration
SENTENCE_TRANSFORMER_MODEL=all-mpnet-base-v2

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000

# Connection Pool Size
DB_POOL_SIZE=10

# Resource Search Cache TTL (hours)
RESOURCE_CACHE_TTL=24

# Enable GPU Acceleration (set to true if CUDA available)
USE_GPU=false

# Enable FAISS Index
USE_FAISS=true

# Log Level
LOG_LEVEL=INFO
